rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == "cmshiyas007@gmail.com";
    }
    function isLoggedIn() {
      return request.auth != null;
    }

    // ── Access requests ───────────────────────────────────────────────────────
    // Each user can read/write their own request doc. Admin can do anything.
    match /access_requests/{email} {
      allow read, write: if isAdmin()
                         || (isLoggedIn() && request.auth.token.email == email);
    }

    // ── Approved users ────────────────────────────────────────────────────────
    // Each approved user can only read their own doc. Admin can read/write all.
    match /approved_users/{email} {
      allow read:  if isAdmin()
                   || (isLoggedIn() && request.auth.token.email == email);
      allow write: if isAdmin();
    }

    // ── Shared config — all logged-in users read, admin writes ────────────────
    match /shared/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── Legacy paths ──────────────────────────────────────────────────────────
    match /tracker/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }
    match /settings/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── Per-user private data — owner only ────────────────────────────────────
    match /users/{uid}/data/{docId} {
      allow read, write: if isLoggedIn() && request.auth.uid == uid;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /access_requests/{email} {
      allow read, write: if request.auth != null &&
        (request.auth.token.email == "cmshiyas007@gmail.com" ||
         request.auth.token.email == email);
    }

    match /approved_users/{email} {
      allow read: if request.auth != null &&
        (request.auth.token.email == "cmshiyas007@gmail.com" ||
         request.auth.token.email == email);
      allow write: if request.auth != null &&
        request.auth.token.email == "cmshiyas007@gmail.com";
    }

    // Tracker data: any signed-in user can read/write
    match /tracker/{document} {
      allow read, write: if request.auth != null;
    }

    // Settings (purchase costs etc): any signed-in user can read, write
    match /settings/{document} {
      allow read, write: if request.auth != null;
    }
  }
}
